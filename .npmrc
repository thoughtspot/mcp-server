# @thoughtspot/* packages consumed here (mcp-auth, rest-api-sdk) are published to
# the PUBLIC npm registry. Pin the scope explicitly so it resolves from public npm
# regardless of any @thoughtspot->Artifactory mapping in a developer's ~/.npmrc.
# This is also required for off-network builds (Cloudflare, GitHub Actions, GHCR).
@thoughtspot:registry=https://registry.npmjs.org/
